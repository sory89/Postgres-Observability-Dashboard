# Copy this file to '.env' — never commit real credentials.

# ── Local Postgres (docker-compose "postgres" service) ──────────────────────
LOCAL_PG_HOST=postgres
LOCAL_PG_PORT=5432
LOCAL_PG_DB=observe
LOCAL_PG_USER=observe
LOCAL_PG_PASSWORD=observe
LOCAL_PG_SSLMODE=disable

# ── External Postgres (filled in via the sidebar form at runtime) ────────────
# Leave blank to type credentials into the dashboard sidebar.
EXT_PG_HOST=
EXT_PG_PORT=5432
EXT_PG_DB=postgres
EXT_PG_USER=postgres
EXT_PG_PASSWORD=
